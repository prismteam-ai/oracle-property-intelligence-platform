# Optional live data mode for a contract-compatible Vercel Postgres/Neon database.
# Leave unset for deterministic fixture mode.
ORACLE_DATA_SOURCE=elephant-query-db
DATABASE_URL=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Required for free-text natural-language RAG.
# Required inquiry chips and structured filters still work without these.
OPENAI_API_KEY=sk-REPLACE_ME
ORACLE_RAG_EMBEDDING_MODEL=text-embedding-3-small
ORACLE_RAG_ANSWER_MODEL=gpt-5.4-mini
ORACLE_RAG_TOP_K=8

# Optional: make live verification fail instead of skip when DATABASE_URL is absent.
REQUIRE_LIVE_QUERY_DB=1

# Optional: make RAG verification fail instead of skip when DATABASE_URL or OPENAI_API_KEY is absent.
REQUIRE_RAG=1
